# Synk environment variables
# Copy this file to .env and fill in your own credentials.
# Never commit the real .env file.

# Alpaca paper-trading API (https://app.alpaca.markets/paper/dashboard/overview)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

# Telegram alerts (create a bot via @BotFather, get chat_id from @userinfobot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# HuggingFace token (optional but recommended). Authenticates the FinBERT model
# download/metadata check -> avoids HF rate-limit warnings, faster cold start.
# Create a READ-scope token at https://huggingface.co/settings/tokens
HF_TOKEN=

# Log directory (relative to repo root)
LOG_DIR=logs/

# --- Defence-beta sleeve (separate buy-and-hold tilt, maintained by the bot) ---
# SAFETY: ships disabled. Bound to ALPACA_PAPER above. When enabled the bot will
# place orders for SLEEVE_SYMBOL to hold it at SLEEVE_TARGET_WEIGHT of total
# equity, rebalanced quarterly (drift band). Held OUTSIDE the gated strategy and
# excluded from the kill-switch risk basis. Set SLEEVE_ENABLED=true only after
# you have reviewed it and are ready to fund the allocation.
SLEEVE_ENABLED=false
SLEEVE_SYMBOL=PPA
SLEEVE_TARGET_WEIGHT=0.15
SLEEVE_DRIFT_BAND=0.03
SLEEVE_REBALANCE_DAYS=90
